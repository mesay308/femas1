# ==============================================
# Backend Environment Configuration Template
# ==============================================
# Copy this file to `.env` and fill in real values
# for each new company deployment.
# ==============================================

# === Database ===
# Use DB_PASSWORD (preferred). DB_PASS is also accepted by setup/seed scripts.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=company_db

# === Server ===
PORT=5000
NODE_ENV=development

# === Security / Authentication ===
JWT_SECRET=CHANGE_ME_to_a_random_64_character_string
JWT_EXPIRES_IN=24h
BCRYPT_SALT_ROUNDS=12
