# Environment Variables Template
# Copy this file to .env.local and fill in the values for your deployment.

# === Backend API ===
# Point this to your backend server (e.g. Express).
NEXT_PUBLIC_API_URL="http://localhost:5000"

# === Public Site URL (used for SEO / OpenGraph / sitemap) ===
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# === Company Identity (overrides DB defaults if set) ===
NEXT_PUBLIC_COMPANY_NAME="Your Company"
NEXT_PUBLIC_COMPANY_LEGAL_NAME="Your Company Ltd."
NEXT_PUBLIC_COMPANY_TAGLINE=""

# === Brand Colors (CSS hex) ===
NEXT_PUBLIC_BRAND_PRIMARY="#2563eb"
NEXT_PUBLIC_BRAND_SECONDARY="#f97316"

# === Locale & Currency ===
NEXT_PUBLIC_DEFAULT_LOCALE="en"
NEXT_PUBLIC_CURRENCY_CODE="USD"
NEXT_PUBLIC_CURRENCY_SYMBOL="$"
